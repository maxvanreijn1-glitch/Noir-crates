# ──────────────────────────────────────────────────────────────────────────────
# Noir Crates — Environment Variables
# Copy this file to .env.local for local development
# ──────────────────────────────────────────────────────────────────────────────

# ── Supabase / Postgres ────────────────────────────────────────────────────────
# Required. Your Supabase Postgres connection string.
# For Vercel serverless use the "Session Mode" (port 5432) pooler URL:
#   Project Settings → Database → Connection string → URI
# Example: postgresql://postgres.xxxx:password@aws-0-eu-west-1.pooler.supabase.com:5432/postgres
DATABASE_URL=postgresql://postgres:[YOUR-PASSWORD]@db.[YOUR-PROJECT-REF].supabase.co:5432/postgres

# ── Stripe ────────────────────────────────────────────────────────────────────
# Required. Your Stripe secret key (sk_live_... or sk_test_...).
STRIPE_SECRET_KEY=sk_test_...

# Optional. Webhook secret for verifying Stripe events.
STRIPE_WEBHOOK_SECRET=whsec_...

# ── JWT Secrets ───────────────────────────────────────────────────────────────
# Required in production. At least 32 random characters each.
# Generate with: openssl rand -base64 32
ADMIN_JWT_SECRET=change-me-min-32-chars-admin-secret-here!!
CUSTOMER_JWT_SECRET=change-me-min-32-chars-customer-secret!!

# ── Admin Seeding ─────────────────────────────────────────────────────────────
# Used by `npm run db:migrate` to create the initial super-admin account.
# If not set, defaults to admin@example.com / ChangeMe123! (UNSAFE in production!)
ADMIN_SEED_EMAIL=admin@yourdomain.com
ADMIN_SEED_PASSWORD=YourSecurePassword123!

# ── App URL ───────────────────────────────────────────────────────────────────
# Optional. Defaults to http://localhost:3000. Used for email links, redirects.
NEXT_PUBLIC_BASE_URL=https://your-domain.vercel.app

# ── Email (optional — currently logs to console in dev) ───────────────────────
# EMAIL_FROM=noreply@yourdomain.com
# RESEND_API_KEY=re_...
# # OR SMTP:
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_USER=user@example.com
# SMTP_PASS=password
